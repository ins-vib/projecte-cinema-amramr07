@startuml
skinparam classAttributeIconSize 0
skinparam linetype ortho
hide empty methods

' ---------- Enumerations ----------
enum SeatType {
    STANDARD
    PREMIUM
    ADAPTED
}

enum OrderStatus {
    PENDING
    CONFIRMED
    CANCELLED
}

enum Role {
    ADMIN
    CLIENT
}

' ---------- Entities ----------
class Cinema {
    - Long id
    - String name
    - String city
    - String adress
}

class Room {
    - Long id
    - String name
    - int capacity
}

class Seat {
    - Long id
    - int seatRow
    - int seatNumber
    - boolean isActive
    - SeatType type
}

class Movie {
    - Long id
    - String title
    - int duration
    - String genre
}

class Screening {
    - Long id
    - LocalDateTime screeningDateTime
    - Double price
}

class Order {
    - Long id
    - LocalDateTime orderDateTime
    - double totalAmount
    - OrderStatus status
}

class Ticket {
    - Long id
    - double price
}

class User {
    - Long id
    - String username
    - Role role
}

' ---------- Relationships ----------
Cinema "1" *-- "0..*" Room : contains >
Room "1" *-- "0..*" Seat : has >
Seat --> SeatType : is >

Screening "0..*" --> "1" Movie : screens >
Screening "0..*" --> "1" Room : held in >

Order "1" *-- "0..*" Ticket : includes >
Order --> OrderStatus : status >

User --> Role : has role >
@enduml


@startuml UseCaseDiagram
left to right direction
skinparam actorStyle awesome

' ---------- Actors ----------
actor "Guest\n(Anonymous)" as Guest
actor "Client\n(ROLE_CLIENT)" as Client
actor "Admin\n(ROLE_ADMIN)" as Admin

Client <|-- Admin

' ---------- Use Cases ----------
package "CinemaDaw System" {

    rectangle "Public Area" {
        usecase "View Billboard" as UC_View
        usecase "Register/Login" as UC_Auth
    }

    rectangle "Client Area" {
        usecase "Select Seats" as UC_Seats
        usecase "Purchase Tickets" as UC_Buy
        usecase "View Cart / Checkout" as UC_Checkout
    }

    rectangle "Admin Area" {
        usecase "Manage Movies" as UC_Movies
        usecase "Manage Sessions" as UC_Sessions
        usecase "Database Access (H2)" as UC_H2
    }
}

' ---------- Associations ----------
Guest --> UC_View
Guest --> UC_Auth

Client --> UC_Seats
Client --> UC_Buy
Client --> UC_Checkout

Admin --> UC_Movies
Admin --> UC_Sessions
Admin --> UC_H2
@enduml
